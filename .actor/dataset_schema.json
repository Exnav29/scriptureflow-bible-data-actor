{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "recordType": {
        "type": "string",
        "title": "Record type",
        "description": "The kind of row written by the Actor.",
        "enum": ["translation", "catalogSummary", "verse", "validation", "error", "book"],
        "example": "verse"
      },
      "mode": {
        "type": "string",
        "title": "Mode",
        "description": "The Actor mode that produced this row.",
        "enum": ["catalog", "catalogSummary", "passage", "validate_reference", "translation_books"],
        "example": "passage"
      },
      "source": {
        "type": "object",
        "title": "Source",
        "description": "ScriptureFlow source metadata for the row, including endpoint, documentation URL, CTA URL, and retrieval time.",
        "example": {
          "provider": "ScriptureFlow",
          "endpoint": "/api/verse",
          "docsUrl": "https://scriptureflow-dev-docs.pages.dev",
          "apiCtaUrl": "https://scriptureflow-dev-docs.pages.dev?utm_source=apify&utm_medium=actor&utm_campaign=scriptureflow_bible_data",
          "retrievedAt": "2026-06-13T00:00:00.000Z"
        }
      },
      "translationId": {
        "type": ["string", "null"],
        "title": "Translation ID",
        "description": "ScriptureFlow translation key, such as en-kjv.",
        "example": "en-kjv"
      },
      "reference": {
        "type": ["string", "null"],
        "title": "Reference",
        "description": "Resolved Scripture reference for verse rows.",
        "example": "John 3:16"
      },
      "inputReference": {
        "type": ["string", "null"],
        "title": "Input reference",
        "description": "Reference string originally supplied by the user.",
        "example": "Romans 8:28"
      },
      "normalizedReference": {
        "type": ["string", "null"],
        "title": "Normalized reference",
        "description": "Reference resolved by ScriptureFlow validation mode.",
        "example": "Romans 8:28"
      },
      "book": {
        "type": ["string", "null"],
        "title": "Book",
        "description": "Resolved Bible book identifier returned by ScriptureFlow.",
        "example": "john"
      },
      "bookSlug": {
        "type": ["string", "null"],
        "title": "Book slug",
        "description": "Book slug returned by ScriptureFlow when available.",
        "example": "john"
      },
      "canonicalBook": {
        "type": ["string", "null"],
        "title": "Canonical book",
        "description": "Canonical book key returned by ScriptureFlow when available.",
        "example": "john"
      },
      "chapter": {
        "type": ["number", "null"],
        "title": "Chapter",
        "description": "Resolved chapter number.",
        "example": 3
      },
      "verse": {
        "type": ["number", "null"],
        "title": "Verse",
        "description": "Resolved verse number.",
        "example": 16
      },
      "text": {
        "type": ["string", "null"],
        "title": "Scripture text",
        "description": "Verse text returned by ScriptureFlow for passage mode.",
        "example": "For God so loved the world..."
      },
      "valid": {
        "type": ["boolean", "null"],
        "title": "Valid",
        "description": "Whether the row represents a valid resolved reference or user-error result.",
        "example": true
      },
      "errorCode": {
        "type": ["string", "null"],
        "title": "Error code",
        "description": "Structured error code for user/input error rows.",
        "example": "UNSUPPORTED_REFERENCE_FORMAT"
      },
      "message": {
        "type": ["string", "null"],
        "title": "Message",
        "description": "Human-readable error message for error rows.",
        "example": "Unsupported reference format."
      },
      "status": {
        "type": ["string", "number", "null"],
        "title": "Status",
        "description": "Translation status for catalog rows, or HTTP status for error rows.",
        "example": 404
      },
      "metadata": {
        "type": ["object", "null"],
        "title": "Metadata",
        "description": "Optional non-text metadata such as source path, API path, ID, and input reference.",
        "example": {
          "id": "en-kjv:john:3:16",
          "sourcePath": "bibles/en-kjv/books/john/chapters/3/verses/16.json",
          "apiPath": "/en-kjv/books/john/chapters/3/verses/16.json",
          "inputReference": "John 3:16"
        }
      },
      "languageCode": {
        "type": ["string", "null"],
        "title": "Language code",
        "description": "Language code returned in catalog rows.",
        "example": "eng"
      },
      "translationName": {
        "type": ["string", "null"],
        "title": "Translation name",
        "description": "Human-readable translation name returned in catalog rows.",
        "example": "King James Version"
      },
      "booksFound": {
        "type": ["number", "null"],
        "title": "Books found",
        "description": "Number of books found in catalog metadata.",
        "example": 66
      },
      "chaptersFound": {
        "type": ["number", "null"],
        "title": "Chapters found",
        "description": "Number of chapters found in catalog metadata or for a book metadata row.",
        "example": 1189
      },
      "firstChapter": {
        "type": ["number", "null"],
        "title": "First chapter",
        "description": "Lowest chapter number found for a book metadata row.",
        "example": 1
      },
      "lastChapter": {
        "type": ["number", "null"],
        "title": "Last chapter",
        "description": "Highest chapter number found for a book metadata row.",
        "example": 21
      },
      "totalVerses": {
        "type": ["number", "null"],
        "title": "Total verses",
        "description": "Sum of chapter verse counts for a book metadata row when available.",
        "example": 879
      },
      "versesFound": {
        "type": ["number", "null"],
        "title": "Verses found",
        "description": "Number of verses found in catalog metadata.",
        "example": 31102
      },
      "versesIndexType": {
        "type": ["string", "null"],
        "title": "Verse index type",
        "description": "Catalog metadata describing the available ScriptureFlow index format.",
        "example": "book-asset"
      },
      "totalTranslations": {
        "type": ["number", "null"],
        "title": "Total translations",
        "description": "Total number of ready translations the Actor read from the catalog for a catalogSummary row.",
        "example": 199
      },
      "discoveredTranslations": {
        "type": ["number", "null"],
        "title": "Discovered translations",
        "description": "Total discovered translation records reported by ScriptureFlow status metadata when available.",
        "example": 211
      },
      "readyTranslations": {
        "type": ["number", "null"],
        "title": "Ready translations",
        "description": "Ready translations currently exposed through the Actor catalog.",
        "example": 199
      },
      "languageCount": {
        "type": ["number", "null"],
        "title": "Language count",
        "description": "Number of unique catalog language codes for a catalogSummary row.",
        "example": 112
      },
      "fullBibleCount": {
        "type": ["number", "null"],
        "title": "Full Bible count",
        "description": "Number of translations whose catalog metadata indicates at least 66 books and 1,189 chapters.",
        "example": 42
      },
      "partialTranslationCount": {
        "type": ["number", "null"],
        "title": "Partial translation count",
        "description": "Number of catalog translations not classified as full Bible by the available coverage metadata.",
        "example": 157
      },
      "newTestamentOnlyCount": {
        "type": ["number", "null"],
        "title": "New Testament only count",
        "description": "Number of translations whose catalog metadata indicates exactly 27 books and 260 chapters.",
        "example": 64
      },
      "topLanguages": {
        "type": ["array", "null"],
        "title": "Top languages",
        "description": "Most represented catalog language codes, sorted by translation count.",
        "example": [{ "languageCode": "eng", "translationCount": 21 }]
      },
      "details": {
        "type": ["object", "null"],
        "title": "Error details",
        "description": "Raw details returned with a structured user/input error when available.",
        "example": {
          "error_code": "VERSION_INDEX_NOT_FOUND"
        }
      }
    },
    "required": ["recordType", "mode", "source"]
  },
